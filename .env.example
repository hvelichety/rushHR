# RushHR Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
# For development on simulator: http://localhost:5001
# For development on device: use ngrok URL or your network IP
# For production: your deployed backend URL
EXPO_PUBLIC_API_URL=https://your-backend-url.com

# API Key for authenticating backend requests (required for /call endpoint)
EXPO_PUBLIC_API_KEY=your-api-key-here

# EAS Configuration (optional)
# Get this from https://expo.dev after creating a project
EAS_PROJECT_ID=your-eas-project-id
